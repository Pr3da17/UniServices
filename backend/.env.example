# Backend server configuration
PORT=3001
NODE_ENV=development

# Moodle instance URL (must be HTTPS in production)
MOODLE_BASE_URL=https://moodle.univ-artois.fr

# Frontend URL for CORS (Very important for production!)
FRONTEND_URL=http://localhost:5173

# Session timeout (milliseconds)
SESSION_TIMEOUT=3600000

# Cache duration for assignments (milliseconds)
CACHE_TTL=300000

# Rate limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW=900000

# ADE Artois Credentials (DO NOT COMMIT REAL PASSWORD HERE)
ADE_USERNAME=your_moodle_username
ADE_PASSWORD=your_moodle_password
